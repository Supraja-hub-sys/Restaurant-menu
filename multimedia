    <!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Music World</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#111;
    color:white;
}

header{
    background:#ff6600;
    padding:20px;
    text-align:center;
}

header h1{
    font-size:40px;
}

nav{
    background:#222;
    padding:15px;
    text-align:center;
}

nav a{
    color:white;
    text-decoration:none;
    margin:20px;
    font-size:18px;
}

.search{
    text-align:center;
    margin:25px;
}

.search input{
    width:60%;
    padding:12px;
    border-radius:20px;
    border:none;
}

.section-title{
    text-align:center;
    margin-top:20px;
    color:orange;
}

.container{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:25px;
    padding:30px;
}

.card{
    width:220px;
    background:#222;
    border-radius:10px;
    overflow:hidden;
    transition:0.3s;
}

.card:hover{
    transform:scale(1.05);
}

.card img{
    width:100%;
    height:250px;
}

.card h3{
    text-align:center;
    padding:10px;
}

.card p{
    text-align:center;
    color:lightgray;
    padding-bottom:10px;
}

audio{
    width:90%;
    margin:15px;
}

footer{
    background:#222;
    text-align:center;
    padding:20px;
    margin-top:30px;
}

</style>

</head>

<body>

<header>

<h1>🎵 Music World</h1>
<p>Latest Telugu Songs Collection</p>

</header>

<nav>

<a href="#">Home</a>
<a href="#">Movies</a>
<a href="#">Songs</a>
<a href="#">Albums</a>
<a href="#">Contact</a>

</nav>

<div class="search">

<input type="text" placeholder="Search Songs...">

</div>

<h2 class="section-title">Latest Songs</h2>

<div class="container">

<div class="card">

<img src="https://picsum.photos/220/250?1">

<h3>Pushpa 2</h3>

<p>2025 Telugu Album</p>

<audio controls>

<source src="sample.mp3" type="audio/mpeg">

</audio>

</div>

<div class="card">

<img src="https://picsum.photos/220/250?2">

<h3>OG</h3>

<p>Action Movie Songs</p>

<audio controls>

<source src="sample.mp3" type="audio/mpeg">

</audio>

</div>

<div class="card">

<img src="https://picsum.photos/220/250?3">

<h3>Devara</h3>

<p>Latest Hits</p>

<audio controls>

<source src="sample.mp3" type="audio/mpeg">

</audio>

</div>

<div class="card">

<img src="https://picsum.photos/220/250?4">

<h3>Hari Hara Veera Mallu</h3>

<p>Melody Songs</p>

<audio controls>

<source src="sample.mp3" type="audio/mpeg">

</audio>

</div>

</div>

<footer>

<p>© 2026 Music World | Multimedia HTML Project</p>

</footer>

</body>
</html>



</head>
<body> 
    
</body>
</html> 
